@page "/settings"
<PageTitle>Playing with Preferences</PageTitle>

<!--
        Theme toggle checkbox.
        @bind="IsDarkMode" connects the checkbox to the IsDarkMode property.
        Toggling updates:
        1. Blazor UI colors (BackgroundColor/TextColor)
        2. MAUI theme via Application.Current.UserAppTheme
        3. Preferences storage for persistence

        BUT Why!!!!?
        Two “layers” in MAUI Blazor Hybrid

            In a MAUI Blazor Hybrid app, you have:
            MAUI layer
                Controls like Label, Button, Entry in XAML or in MAUI pages
                Application.Current.UserAppTheme affects these controls directly
                System/dark/light theme-aware resources update automatically
            Blazor layer
                HTML elements (<div>, <p>, <input>) rendered in the WebView
                They are not MAUI controls
                They don’t automatically respond to Application.Current.UserAppTheme

        Explanation
        MAUI Layer
            Real native controls
            Automatically respects Application.Current.UserAppTheme
        Blazor Layer
            Rendered as HTML in a WebView
            Has no direct knowledge of MAUI theme settings
            Must use bound properties or CSS to reflect changes
        The <div> acts as a “bridge”
            Changes its background/text color based on IsDarkMode
            Gives visual feedback inside the Blazor page

        Visual analogy
        Think of MAUI as the room
        Blazor WebView is a picture frame on the wall inside the room
        Changing the room light (UserAppTheme) does not automatically
            change the picture colors
        You need to manually adjust the picture colors (the <div>)
    -->
<label>
    This label control is in the WebView of a <string>razor page</string> which does not
        react automatically to preferences.
</label>

@* <div style="background-color:@BackgroundColor; color:@TextColor; min-height:100vh; padding:20px;"> *@
    <h3>Settings</h3>
    <h4> ....playing with Preference settings</h4>

    <div class="mb-3">
        <label>Dark Mode</label> <br/>
        <input type="checkbox" @bind="IsDarkMode"/>
    </div>

    <p>@ThemeText</p>

    <h5>Last Launch:</h5>
    <p>@LastLaunch</p>
@* </div> *@
@code {
    [Inject]
    public NavigationManager _navManager { get; set; }
    private bool initSwitch = false;
    private bool _isDarkMode;
    private bool IsDarkMode
    {
        get => _isDarkMode;
        set
        {
            //Changing the checkbox triggers
            //  the setter runs→
            //  saves (updated) preference →
            //  applies theme →
            //  updates label →
            //  force refresh of page by navigating to one's self
            //      this is predicable behaviour
            _isDarkMode = value;

            //set the app_theme preferences to the current condition indicated by the
            //  checkbox. Checked: dark UnChecked: light
            //persist the change to the preferences so that when
            //  the application runs again, the theme will be
            //  as last set
            Preferences.Set("app_theme", value ? "dark" : "light");

            ApplyTheme(value);
            UpdateThemeText();

            //hack work around to get this page to reload with the update theme
            //this causes a global refresh trigger
            //      Layout re-evaluation
            //      Component re-creation
            //      state reload from Preferences
            //this works because it forced
            //  Dispose → Recreate → Reinitialize → Re-read Preferences

            //a preferred method and more controlled is to use a Notification technique
            //However: In Blazor (especially MAUI Blazor Hybrid):
            //  The order of initialization between pages and MainLayout is NOT guaranteed.
            //This means that even though you code the Notification correctly, it may not
            //  work as expected.

            //THIS IS A EVENT TIMING ISSUE!!!

            // Think of it like this:
            //      Event system → elegant but timing-sensitive
            //      Navigation refresh → brute force but predictable

            if (!initSwitch)
                _navManager.NavigateTo("settings", forceLoad: true);
        }
    }
    private string ThemeText = "";
    private string LastLaunch = "";

    //setup and assignment of the variables used on the style statement
    // private string BackgroundColor => IsDarkMode ? "black" : "white";
    // private string TextColor => IsDarkMode ? "white" : "black";

    protected override void OnInitialized()
    {
        base.OnInitialized();
        //load the theme
        //obtains the current theme, if notjing obtained, defaults to light
        var savedTheme = Preferences.Get("app_theme", "light");

        initSwitch = true;
        //save the data of whether the DarkMode is on (true) or off (false)
        IsDarkMode = savedTheme == "dark";
        initSwitch = false;


    }

    private void ApplyTheme(bool isdark)
    {
        /*
       * Application.Current.UserAppTheme is a MAUI-level property.
         It controls the app’s global theme for all MAUI controls
                      (XAML controls like Label, Button, Entry)
              Works on Android, iOS, Mac, and Windows
         Changing this does not automatically update Blazor HTML inside the WebView
              — that’s why we manually bind <div> colors.
         Any MAUI controls on the page that support theme-aware styles will
              immediately react when you call ApplyTheme.
       */
        Application.Current.UserAppTheme = isdark ? AppTheme.Dark : AppTheme.Light;

    }

    private void UpdateThemeText()
    {
        ThemeText = IsDarkMode ? "Dark Mode" : "Light Mode";
    }
}
